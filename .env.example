# Copy this file to .env.local and fill in the values from your Supabase project
# Settings → API in the Supabase dashboard

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...your-publishable-key...

# Web push (optional for local dev — pushes just stay off without it).
# The PUBLIC half of the VAPID pair; generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=
